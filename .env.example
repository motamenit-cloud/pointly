# ─── Pointly Next.js App Environment Variables ───────────────────────────────
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# ── Supabase (auth + database) ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Scraper worker (live award data) ─────────────────────────────────────────
# URL where the scraper-worker service is running
SCRAPER_WORKER_URL=http://localhost:4000
# Must match SCRAPER_API_KEY in scraper-worker/.env
SCRAPER_API_KEY=your-secret-key-here
# How long to wait for a scrape response in ms (default 30000)
SCRAPER_TIMEOUT=30000

# ── Upstash Redis (scraper result cache) ─────────────────────────────────────
# Create a free database at https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# ── Amadeus (real cash flight prices) ────────────────────────────────────────
# Free tier available at https://developers.amadeus.com/
AMADEUS_API_KEY=your-api-key
AMADEUS_API_SECRET=your-api-secret

# ── Seats.aero (optional — award availability cache) ─────────────────────────
# Paid API, not required — Claude agents replace this
# SEATS_AERO_API_KEY=your-key

# ── Cron jobs ─────────────────────────────────────────────────────────────────
CRON_SECRET=your-cron-secret
