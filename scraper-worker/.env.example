# ─── Scraper Worker Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Required for Claude AI agents ────────────────────────────────────────────
# Powers the Air Canada, British Airways, Flying Blue, Southwest, and JetBlue
# scrapers. Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Required: shared secret between the Next.js app and this worker ───────────
# Must match SCRAPER_API_KEY in your Next.js .env.local
# Generate with: openssl rand -hex 32
SCRAPER_API_KEY=your-secret-key-here

# ── Optional: port the worker listens on (default 4000) ──────────────────────
PORT=4000

# ── Optional: proxy for anti-bot evasion ─────────────────────────────────────
# Single proxy (residential proxies work best):
# PROXY_URL=http://user:pass@host:port
#
# Multiple proxies for rotation (comma-separated):
# PROXY_URLS=http://user:pass@host1:port,http://user:pass@host2:port

# ── Optional: airline credentials for authenticated scrapers ──────────────────
# Needed only if you add login-gated scrapers (Delta, Alaska, etc.)
# DELTA_USERNAME=your@email.com
# DELTA_PASSWORD=your-password
# ALASKA_USERNAME=your@email.com
# ALASKA_PASSWORD=your-password
